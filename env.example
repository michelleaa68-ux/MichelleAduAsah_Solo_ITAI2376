# .env.example

# LLM API keys (required if upgrading agents to use a language model)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Image generation API (required if upgrading MIZEL to generate real mood board images)
STABILITY_API_KEY=

# Database connection (required if upgrading MILO to use a real inventory database)
DATABASE_URL=

# Worker passcode (required if moving MILO passcode out of the source code)
WORKER_PASSCODE=
